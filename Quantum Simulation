<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Extreme Wave Stacking Sim</title>
    <style>
        body { font-family: 'Segoe UI', sans-serif; background: #08080a; color: #e0e0e0; display: flex; flex-direction: column; align-items: center; padding: 20px; }
        canvas { background: #000; border: 1px solid #444; border-radius: 8px; }
        .ui-container { background: #16161c; padding: 25px; border-radius: 12px; margin-top: 20px; width: 900px; border: 1px solid #333; }
        .controls { display: grid; grid-template-columns: 1fr 1fr; gap: 40px; }
        .slider-group { position: relative; padding-bottom: 20px; }
        label { font-size: 0.7em; text-transform: uppercase; color: #888; letter-spacing: 2px; display: block; margin-bottom: 10px; }
        input[type=range] { width: 100%; cursor: pointer; accent-color: #00d4ff; }
        .ticks { display: flex; justify-content: space-between; margin-top: 5px; font-size: 10px; color: #555; position: relative; }
        .neutral-tick { position: absolute; left: 50%; transform: translateX(-50%); color: #00d4ff; font-weight: bold; }
        button { padding: 12px; font-weight: bold; cursor: pointer; border-radius: 6px; border: none; background: #00d4ff; color: #000; width: 100%; margin-bottom: 20px; }
        button.paused { background: #ff4d4d; color: #fff; }
        .stats { background: #000; padding: 15px; border-radius: 6px; font-family: monospace; border: 1px solid #222; margin-top: 20px; display: flex; justify-content: space-around; }
    </style>
</head>
<body>

    <h2 style="font-weight: 300;">Enhanced Wave Stacking (50% Emission Rate)</h2>
    <canvas id="simCanvas" width="1000" height="400"></canvas>

    <div class="ui-container">
        <button id="pauseBtn">PAUSE ENGINE</button>
        <div class="controls">
            <div class="slider-group">
                <label>Velocity (v/c): <span id="vDisplay" style="color:white">0.40</span></label>
                <input type="range" id="vSlider" min="-0.60" max="0.60" step="0.01" value="0.40">
                <div class="ticks"><span>-0.6c</span><span class="neutral-tick">0.0</span><span>0.6c</span></div>
            </div>
            <div class="slider-group">
                <label>Rest Wavelength ($\lambda_0$): <span id="wDisplay" style="color:white">550</span> nm</label>
                <input type="range" id="waveSlider" min="400" max="700" step="1" value="550">
                <div class="ticks"><span>400</span><span class="neutral-tick">550</span><span>700</span></div>
            </div>
        </div>
        <div class="stats">
            <div style="color: #4d94ff;">Front λ: <span id="fWave">--</span></div>
            <div style="color: #ff4d4d;">Back λ: <span id="bWave">--</span></div>
        </div>
    </div>

    <script>
        const canvas = document.getElementById('simCanvas');
        const ctx = canvas.getContext('2d');
        const vSlider = document.getElementById('vSlider');
        const waveSlider = document.getElementById('waveSlider');
        const pauseBtn = document.getElementById('pauseBtn');

        let waves = [];
        let isPaused = false;
        let time = 0;
        
        // c_sim reduced to 1.8 to "crunch" the waves together (2x stacking intensity)
        const c_sim = 1.8; 
        let emitterX = canvas.width / 2;

        pauseBtn.onclick = () => {
            isPaused = !isPaused;
            pauseBtn.innerText = isPaused ? "RESUME ENGINE" : "PAUSE ENGINE";
            pauseBtn.classList.toggle("paused", isPaused);
        };

        function nmToRGB(wavelength) {
            let r, g, b;
            if (wavelength < 380) return "rgb(100, 0, 255)"; 
            if (wavelength > 780) return "rgb(150, 0, 0)";
            if (wavelength >= 380 && wavelength < 440) { r = -(wavelength - 440) / (440 - 380); g = 0; b = 1; }
            else if (wavelength >= 440 && wavelength < 490) { r = 0; g = (wavelength - 440) / (490 - 440); b = 1; }
            else if (wavelength >= 490 && wavelength < 510) { r = 0; g = 1; b = -(wavelength - 510) / (510 - 490); }
            else if (wavelength >= 510 && wavelength < 580) { r = (wavelength - 510) / (580 - 510); g = 1; b = 0; }
            else if (wavelength >= 580 && wavelength < 645) { r = 1; g = - (wavelength - 645) / (645 - 580); b = 0; }
            else { r = 1; g = 0; b = 0; }
            return `rgb(${r * 255}, ${g * 255}, ${b * 255})`;
        }

        class Peak {
            constructor(x) {
                this.x = x;
                this.y = canvas.height / 2;
                this.radius = 0;
            }
            update() { this.radius += c_sim; }
        }

        function animate() {
            if (!isPaused) {
                ctx.fillStyle = '#000';
                ctx.fillRect(0, 0, canvas.width, canvas.height);

                const v = parseFloat(vSlider.value);
                const lambda0 = parseFloat(waveSlider.value);
                const factorFront = Math.sqrt((1 - v) / (1 + v));
                const factorBack = Math.sqrt((1 + v) / (1 - v));
                const lambdaFront = lambda0 * factorFront;
                const lambdaBack = lambda0 * factorBack;

                emitterX += v * c_sim;
                if (emitterX > canvas.width || emitterX < 0) {
                    waves = [];
                    emitterX = emitterX > canvas.width ? 0 : canvas.width;
                }

                // Emission rate reduced by 50% (from every 8 frames to every 16)
                if (time % 16 === 0) {
                    waves.push(new Peak(emitterX));
                }

                waves.forEach((p, i) => {
                    p.update();
                    ctx.lineWidth = 2;
                    
                    // Front
                    ctx.beginPath();
                    ctx.arc(p.x, p.y, p.radius, Math.PI*1.5, Math.PI*0.5, v < 0);
                    ctx.strokeStyle = nmToRGB(v >= 0 ? lambdaFront : lambdaBack);
                    ctx.stroke();

                    // Back
                    ctx.beginPath();
                    ctx.arc(p.x, p.y, p.radius, Math.PI*0.5, Math.PI*1.5, v < 0);
                    ctx.strokeStyle = nmToRGB(v >= 0 ? lambdaBack : lambdaFront);
                    ctx.stroke();

                    if (p.radius > 1000) waves.splice(i, 1);
                });

                // Emitter with Glow
                const grad = ctx.createRadialGradient(emitterX, canvas.height/2, 0, emitterX, canvas.height/2, 15);
                grad.addColorStop(0, "white");
                grad.addColorStop(1, nmToRGB(v >= 0 ? lambdaFront : lambdaBack));
                ctx.fillStyle = grad;
                ctx.beginPath();
                ctx.arc(emitterX, canvas.height/2, 10, 0, Math.PI*2);
                ctx.fill();

                document.getElementById('vDisplay').innerText = v.toFixed(2);
                document.getElementById('wDisplay').innerText = lambda0;
                document.getElementById('fWave').innerText = Math.round(v >= 0 ? lambdaFront : lambdaBack) + " nm";
                document.getElementById('bWave').innerText = Math.round(v >= 0 ? lambdaBack : lambdaFront) + " nm";

                time++;
            }
            requestAnimationFrame(animate);
        }
        animate();
    </script>
</body>
</html>
